@use "./breakpoints" as *;
@use "./colors" as *;



/*  Breakpoint/General visiblity/display utils */

input:-webkit-autofill,
input:-webkit-autofill:hover,
input:-webkit-autofill:focus,
input:-webkit-autofill:active {
    transition: background-color 5000000s ease-in-out 0s;
}


.styled-scroll {

    &::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    
    /* Track */
    &::-webkit-scrollbar-track {
        background-color: hsla(137, 20%, 41%, 0.2);
        background-clip: padding-box;
        border-right: 4px solid transparent;
        border-left: 4px solid transparent; 
        border-radius: 16px;
        margin-top: 28px;
        margin-bottom: 22px;
    }

    /* Handle */
    &::-webkit-scrollbar-thumb {
        background-color: purple;
        border-radius: 24px;
        background-clip: padding-box;
    }
}


.hidden { 
    visibility: hidden;
    height: 0;
}

.display-none {
    display: none;
}

.reset-visible {
    display: initial !important;
}

.flip-grid-row {
    grid-row: 1;
}

.grid-end {

}

.no-touch {
    pointer-events: none;
    opacity: .5;
}

.hidden-sm { 
    @include media-breakpoint-down(sm) { 
        display: none !important;
    }
}

.hidden-md {
    @include media-breakpoint-only(md) { 
        display: none !important;
    }
}

.hidden-md-down {
    @include media-breakpoint-down(md) { 
        display: none !important;
    }
}

.hidden-lg-down {
    @include media-breakpoint-down(lg) { 
        display: none !important;
    }
}

.hidden-lg { 
    @include media-breakpoint-up(lg) { 
        display: none !important;
    }
}

.hidden-xl { 
    @include media-breakpoint-up(xl) { 
        display: none !important;
    }
}

.visible-sm {
    @include media-breakpoint-up(sm) { 
        display: none !important;
    }
}

.visible-md {    
    @include media-breakpoint-down(sm) { 
        display: none !important;
    }
}

.only-lg { 
    @include media-breakpoint-down(lg) { 
        display: none !important;
    }
}

.only-md { 
    display: none; 
    @include media-breakpoint-only(md) { 
        display: block !important;
    }
}

.only-sm { 
    @include media-breakpoint-up(sm) {
        display: none !important;
    }
}

.visible-only-sm { 
    @include media-breakpoint-down(sm) {
        display: block !important;
    }
}


/* Transform Utils */ 
.rotate-90 { 
    transform: rotate(90deg);
}

.rotate-180 { 
    transform: rotate(180deg);
}

.text-dark { 
    color: black;
}


/* Grid utils */
.grid { 
    display: grid;
}

.grid-2-col { 
    grid-template-columns: repeat(2, 1fr);
} 

.grid-sm-1-col { 
    @include media-breakpoint-down(md) { 
        grid-template-columns: 1fr;
    }
}

.relative {
    position: relative;
}

/* utils */
.flex-row { 
    display: flex;
    flex-direction: row;
}

.flex-wrap { 
    flex-wrap: wrap;
}

.space-between { 
    justify-content: space-between !important;
}

.space-around { 
    justify-content: space-around !important;
}

.flex-end { 
    justify-content: flex-end !important;
}

.flex-start { 
    justify-content: flex-start !important;
}

.justify-center { 
    justify-content: center;
}

.justify-end { 
    justify-content: end;
}


.items-center { 
    align-items: center;
}

.self-center { 
    align-self: center;
}

.flex-col { 
    display: flex; 
    flex-direction:column;
}
.no-wrap { 
    flex-wrap: nowrap !important;
}
.row-gap-8 { 
    row-gap: 8px;
}
.col-gap-8 { 
    column-gap: 8px;
}

.row-gap-16 { 
    row-gap: 16px;
}
.row-gap-32 { 
    row-gap: 32px;
}


/* Text color utils - most typography styles (sizes, weights) are defined in typography.scss */
.text-white { 
    color: white;
}

/* Margin utilities */
.mx-auto { 
    margin: 0 auto;
}
.mt-24 { 
    margin-top: 24px !important;
}
.mt-32 { 
    margin-top: 32px !important;
}
.mt-40 { 
    margin-top: 40px !important;
}

.mt-48 { 
    margin-top: 48px !important;
}

.mt-60 { 
    margin-top: 60px !important;
}

.mt-16 { 
    margin-top: 16px;
}

.ml-16 { 
    margin-left: 16px;
}
.mb-8 { 
    margin-bottom: 8px;
}
.mb-16 { 
    margin-bottom: 16px;
}
.mb-24 { 
    margin-bottom: 24px;
}

.mb-32 { 
    margin-bottom: 32px;
}

.pt-footer {
    padding-top: 50px;

    @include media-breakpoint-down(md) { 
        padding-top: 20px;
    }
}

/* Overflow utils */
.no-scroll { 
    overflow-y: hidden;
}

.text-center { 
    text-align: center !important;
}

.margin-auto {
    margin: auto;
}

/* Adds margin to text + icon divs */
.icon-and-text { 
    display: flex;
    flex-direction: row;
    align-items: center;
    column-gap: 8px;
    cursor: pointer;
}

.remove-bottom-border { 
    border-bottom: none !important;
}


.circle { 
    border-radius: 100%;
}

.h-24 { 
    height: 24px;
}
.w-24 { 
    width: 24px;
}


.transition-transform { 
    transition: transform 0.6s;
}

.svg-to-bright-green { 
    filter: invert(1) brightness(55%) sepia(140%) hue-rotate(85deg) saturate(347%);
}

.svg-to-green-core-dark-tint { 
    filter: invert(1) brightness(37%) sepia(140%) hue-rotate(84deg) saturate(127%);
}

.svg-to-dark-green { 
    filter: invert(1) brightness(20%) sepia(140%) hue-rotate(90deg) saturate(547%);
}

.svg-to-blue { 
    filter: hue-rotate(106deg) brightness(0.6) saturate(1.5);
}

