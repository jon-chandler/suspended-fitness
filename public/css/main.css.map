$max-w-01-s: 600px;
$max-w-01: 860px;
$max-w-02: 1365px;
$max-w-03: 1599px;

$container-w: 1680px;


  	/* 
  		ALL BREAKPOINTS NEED DOING PROPERLY... 
  		THIS IS UTTER SHITE
  	*/

.pole {
 	content: '';
	width: 12px;
	height: var(--defHeight, 200vh);
	background: white;
	display: block;
	position: absolute;
	transform: translateY(-50%);
	overflow: hidden;
 }

 #background-animation {
 	position: absolute;
 	top: 0;
 	left: 50%;
 	transform: translateX(-50%);
 	width: 100vw;
	height: auto;
	min-height: 500vh;
 	z-index: 1;
 	max-width: $container-w;
 	overflow: hidden;
 	pointer-events: none;
 	
 	& > * {
 		pointer-events: none;
 	}

	
	.js-parallax-elem {
		transition: $transition-m;
		opacity: 0;

		&.show {
			opacity: 1;
			transition: $transition-s;
		}
	}

 	.parallax-elem {
		position: absolute;
		transition: opacity $transition-f;

		&:last-of-type {
			bottom: 0;
		}

		img {
			min-width: max-content;
		}

		&--sticky-bottom {
			bottom: 0 !important;

			&:before {
				bottom: 0;
			}

			img {
				margin-top: -100%;
			}

			@include media-breakpoint-down(lg) {
				img {
					margin-top: 50% !important;
				}
			}


		}

		&.constrained-height {
			overflow: hidden;
			bottom: 0;
			top: unset;
			max-height: unset;
			display: flex;
			align-items: flex-end;
			transition: transition-s;
			
			.js-parallax-elem {
				transform: translateY(80%);
				position: relative;
				bottom: 100vh;
				top: unset;

				img {
					margin-top: 0 !important;
				}
			}

			@include media-breakpoint-down(md) {
				width: 150vw;
				left: -20% !important;
       			transform: scale(.75);
				

				.js-parallax-elem {
					bottom: 225vh;
					transform: scale(.7);
				}

				&.v-long {
					left: unset !important;
					overflow: unset;

					&:before {
						min-height: 300vh;
					}

					&.parallax-elem--sticky-bottom {

						.js-parallax-elem {
							bottom: -15vh;
						}
					}

					.js-parallax-elem {
						bottom: 100vh;
					}

						&.offer-page {
							.js-parallax-elem {
								bottom: 20vh;
							}
						}

						&.booking-page {
							overflow: unset;

							&:before {
								min-height: 300vh;
							}

							.js-parallax-elem {
								bottom: 0;
							}
						}
				}
			}

			&--stumpy {
				
				.js-parallax-elem {
					bottom: 165vh;
				}

				@include media-breakpoint-down(sm) {

					.js-parallax-elem {
						bottom: 180vh;
					}
				}
			}

			&--jumbo {

				.js-parallax-elem {
					bottom: 30vh;
				}
			}

			&.overflow {
				overflow: visible;
			}

			&:before {
				min-height: 600vh;
				max-height: 600vh !important;
				transform: translateY(30%);
			}
		}





	}


	.empty-pole {
		left: 10%;

	  	&:before {
	  		@extend .pole;
	  		min-height: 300%;
	  	}

	  	@include media-breakpoint-down(lg) {
	  		display: none;
	  	}
	}

	$lPos: 0;
	@while $lPos <= 100 {

	  .empty-pole--#{$lPos} {
	    left: #{$lPos}#{'%'};
	  }

	  $lPos: $lPos + 5;
	}

	.parallax-area-01 {
		left: 46%;
		top: 2%;

	  	&:before {
	  		@extend .pole;
	  		left: 44px;
	  	}

		@media (max-width: $max-w-02) {
	  		left: 70%;
	  	}

		@media (min-width: $max-w-01) and (max-width: $max-w-02)  {
	  		left: 52%;
	  		transform: scale(.9);
	  	}

	  	@media (min-width: $max-w-01-s) and (max-width: $max-w-01)  {
	  		left: 52%;
	  		transform: scale(.9);
	  	}
	  	

	  	@media (max-width: $max-w-01-s) {
	  		left: 59%;
	  		transform: scale(.6);

	  		&:before {
	  			left: 44px;
	  		}

	  		img {
	  			transform: translateY(-50%);
	  		}
	  	}

	}

	.parallax-area-02 {
	  	left: 63%;
	  	
	  	&:before {
	  		@extend .pole;
	  		left: 24px;
	  	}

	  	@media (min-width: $max-w-01) and (max-width: $max-w-02)  {
	  		left: 80%;
	  	}

	  	@media (max-width: $max-w-01) {
	  		opacity: 0;
	  	}

	}

	.parallax-area-03 {
	  	left: 74%;
	  	top: 9%;

	  	&:before {
	  		@extend .pole;
	  		left: 44px;
	  	}

	  	&.offer-page {
	  		left: 80%;

	  		&:before {
	  			left: 63px;
	  			width: 10px;
	  		}

	  		&:after {
	  			@extend .pole;
	  			width: 10px;
	  			left: 63px;
	  			top: 325%;
	  			height: 500%;
	  			z-index: -1;
	  		}
	  	}

	  	@media (max-width: $max-w-02) {
	  		opacity: 0;
	  	}
	}


	.parallax-area-05 {
	  	left: 60%;

	  	&:before {
	  		@extend .pole;
	  		left: 61px;
	  	}

	  	&.offer-page {
	  		left: 65%;

	  		&:before {
	  			left: 17px;
	  			max-height: 300vh;
	  		}

	  		&:after {
	  			@extend .pole;
	  			left: 7%;
	  			top: 350%;
	  			height: 1000%;
	  			z-index: -1;
	  		}
	  	}

	  	img {
	  		margin-top: -20%;
	  	}

	  	@include media-breakpoint-down(md) {
	  		transform: scale(.6);
	  		left: 56.5%;
	  	}
	}

	.parallax-area-04 {
		left: 10%;

		&:before {
	  		@extend .pole;
	  		left: 135px;
    		width: 15px;
    		max-height: 200vh;
    		transform: translateY(-20%);
	  	}


	  	&.v-long{
	  		left: 15%;

	  		&:before{
	  			left: 41px;
	  			max-height: 500%;
	  		}

	  		img {
				margin-top: 70%;
			}
	  	}

	  	&.offer-page {
	  		left: 32%;

	  		&:before {
	  			left: 44px;
	  			width: 10px;
	  		}
	  	}

/*	  	@include media-breakpoint-down(lg) {
	  		img {
	  			margin-top: -50%;
	  		}
	  	}*/

	  	
