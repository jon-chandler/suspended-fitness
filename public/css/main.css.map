.card-container {
	padding-bottom: 92px;
}


.card {
	border-radius: 0;
	padding: 4em;
	align-self: baseline;
	
	@include media-breakpoint-down(lg) { 
		margin-left: 0;
	}

	@include media-breakpoint-down(md) { 
		padding: 4em 1.5em;
	}

	&:nth-of-type(2) {
		margin-top: 130px;
		align-self: self-start;
		
		@include media-breakpoint-down(lg) { 
			margin-top: 0px;
		}
	}

	&--pull-left {
		margin-left: 0;
		transform: translateX(-2em);

		@include media-breakpoint-down(lg) { 
	        transform: translateX(0);
	    }
	}

	&--top {
		z-index: 2;
	}

	&--white {
		background: $whiteIsh;
	}

	&--pink {
		background: $corePink;
	}

	&--blue {
		background: $coreBlue;
	}

	&--altBlue {
		background: $altBlue;
	}

	&--grey {
		background: $nGrey;
	}

	&--yellow {
		background: $altYellow;
	}

	img {
		min-width: 100%;
	}
}
