.content { 

    padding-top: 170px;
    padding-bottom: 220px;
    min-height: 600px;

    @include media-breakpoint-between(xl, 2xl) { 
    	.col-xl-3 {
    		width: 33%;
    	}
    }

    @include media-breakpoint-down(md) {
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 40px;
    }

    &--align-top {
        padding-top: 240px;
        padding-bottom: 44px;
        min-height: unset;
    }

    &--white {
        color: white;
    }

 }

 .over-anim {
 	position: relative;
 	z-index: 2;
 }

 .generalPadding {
 	padding-left: 92px;
    padding-right:  92px;
    padding-top: 46px;

    @include media-breakpoint-down(xl) { 
        padding-left: 46px;
        padding-right: 46px;

    }

    @include media-breakpoint-down(md) { 
        padding-left: 24px;
        padding-right: 24px;
    }

    & > * { 
        max-width: 1440px;
        margin: 0 auto;
    }

    @include media-breakpoint-down(sm) {
        overflow-wrap: normal;
    }
 }

 .susfit {
 	@extend .generalPadding;
    overscroll-behavior-y: none;
    overflow-x: clip;
    position: relative;

    @include media-breakpoint-down(md) {
        padding-left: 0;
        padding-right: 0;
    }
 }

 .map-container {
    width: 100%;
    height: auto;
    min-height: 360px;
    margin-bottom: 2em;
    position: relative;
 }

#map-launch{
    background: url(../images/zoom.svg);
    position: relative;
    top: 350px;
    left: 88%;
    z-index: 1;
    width: 34px;
    height: 34px;
    display: block;
    cursor: pointer;

    &:hover {
        opacity: .6;
    }
}
