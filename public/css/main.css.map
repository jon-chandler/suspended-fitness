		  		}
		  	}
*

	  	@include media-breakpoint-down(md) {
	  		transform: scale(.7);
	  		//top: 62% !important;
	  		width: 100%;


		  	&:before {
		  		max-height: 100%;
	    		//transform: translateY(-50%);
		  	}
	  	&.v-long {
		  		&:before {
		  			//max-height: 350%;
	    			//transform: translateY(-50%);
	    			//top: 65%;
	  				//left: 5%;
		  		}
		  	
	  	}

	  	/*
	  	@include media-breakpoint-down(sm) {
	  		left: -18%;

	  		&.v-long {
	  			top: 65%;
	  			left: 5%;
	  		}
	  	}

	*/

	  	@media (orientation: landscape) AND  (max-width: $max-w-02) {
	  		margin-top: 10%;

	  		
	  		&:before {
		  		max-height: 130%;
		  	}
	  	}

	}
 }
