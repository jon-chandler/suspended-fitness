$max-w-01: 600px;
$max-w-02: 1400px;
$max-w-03: 1600px;

$container-w: 1600px;

.pole {
 	content: '';
	width: 12px;
	height: 120vh;
	background: white;
	display: block;
	position: absolute;
 }

 #background-animation {
 	position: absolute;
 	top: 0;
 	left: 50%;
 	transform: translateX(-50%);
 	width: 100vw;
	height: auto;
	min-height: 200vh;
 	z-index: 1;
 	//overflow: hidden;
 	max-width: $container-w;
 	
	.js-parallax-elem {
		opacity: 0;
	}

	.add-trans {
		transition: .6s;
		opacity: 1;
	}

 	.parallax-elem {
		position: absolute;
		

		img {
			min-width: max-content;
		}
	}
	.parallax-area-01 {
	  	left: 670px;
	  	margin-top: -320px;

	  	&:before {
	  		@extend .pole;
	  		left: 44px;
	  	}

	  	@media (max-width: $max-w-01) {
	  		margin-left: -340px;
	  	}
	}
	.parallax-area-02 {
	  	left: 918px;
	  	margin-top: -180px;

	  	&:before {
	  		@extend .pole;
	  		left: 24px;
	  	}

	  	@media (max-width: $max-w-02) {
	  		opacity: 0;
	  	}

	}
	.parallax-area-03 {
	  	left: 1123px;
	  	margin-top: -180px;

	  	&:before {
	  		@extend .pole;
	  		left: 44px;
	  	}

	  	@media (max-width: $max-w-03) {
	  		opacity: 0;
	  	}
	}

	.parallax-area-04 {
	  	left: 230px;
	  	padding-top: 800px;
	  	
	  	&:before {
	  		@extend .pole;
	  		left: 136px;
	  	}

	  	img {
	  		margin-top: -100px;
	  	}

	  	@media (max-width: $max-w-02) {
	  		opacity: 0;
	  	}
	}
 }
