.card-container {
	padding-bottom: 92px;
}


.card {
	border-radius: 0;
	padding: 4em;
	align-self: baseline;
	
	@include media-breakpoint-down(lg) { 
		margin-left: 0;
	}

	&:nth-of-type(2) {
		margin-top: 130px;
		align-self: self-start;
		
		@include media-breakpoint-down(lg) { 
			margin-top: 16px;
		}
	}

	&--white {
		background: $whiteIsh;
	}

	&--pink {
		background: $corePink;
	}

	&--blue {
		background: $coreBlue;
	}

	&--altBlue {
		background: $altBlue;
	}

	&--grey {
		background: $nGrey;
	}

	&--yellow {
		background: $altYellow;
	}

	img {
		min-width: 100%;
	}
}

.pull-left-30 {
	margin-left: -4em;

	@include media-breakpoint-down(lg) { 
        margin-left: 0;
    }
}