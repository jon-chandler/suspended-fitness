$max-w-01-s: 600px;
$max-w-01: 860px;
$max-w-02: 1365px;
$max-w-03: 1599px;

$container-w: 1600px;


.pole {
 	content: '';
	width: 12px;
	height: var(--defHeight, 200vh);
	background: white;
	display: block;
	position: absolute;
	transform: translateY(-50%);
	overflow: hidden;
 }

 #background-animation {
 	position: absolute;
 	top: 0;
 	left: 50%;
 	transform: translateX(-50%);
 	width: 100vw;
	height: auto;
	min-height: 500vh;
 	z-index: 1;
 	max-width: $container-w;
 	overflow: hidden;
 	pointer-events: none;

 	& > * {
 		pointer-events: none;
 	}

	
	.js-parallax-elem {
		transition: $transition-m;
		opacity: 0;

		&.show {
			opacity: 1;
			transition: $transition-s;
		}
	}

 	.parallax-elem {
		position: absolute;
		transition: opacity $transition-f;


		&:last-of-type {
			bottom: 0;
		}

		img {
			min-width: max-content;
		}

		&--sticky-bottom {
			top: 55%;

			img {
	  			margin-top: -95%;
	  		}


		}
	}


	.empty-pole {
		left: 10%;

	  	&:before {
	  		@extend .pole;
	  		min-height: 300%;
	  	}

	  	@include media-breakpoint-down(lg) {
	  		display: none;
	  	}
	}

	$lPos: 0;
	@while $lPos <= 100 {

	  .empty-pole--#{$lPos} {
	    left: #{$lPos}#{'%'};
	  }

	  $lPos: $lPos + 5;
	}

	.parallax-area-01 {
		left: 46%;
		top: 2%;

	  	&:before {
	  		@extend .pole;
	  		left: 44px;
	  	}

		@media (max-width: $max-w-02) {
	  		left: 70%;
	  	}

		@media (min-width: $max-w-01) and (max-width: $max-w-02)  {
	  		left: 52%;
	  		transform: scale(.9);
	  	}

	  	@media (min-width: $max-w-01-s) and (max-width: $max-w-01)  {
	  		left: 52%;
	  		transform: scale(.9);
	  	}
	  	

	  	@media (max-width: $max-w-01-s) {
	  		left: 59%;
	  		transform: scale(.6);

	  		&:before {
	  			left: 44px;
	  		}

	  		img {
	  			transform: translateY(-50%);
	  		}
	  	}

	}

	.parallax-area-02 {
	  	left: 61%;
	  	
	  	&:before {
	  		@extend .pole;
	  		left: 24px;
	  	}

	  	@media (min-width: $max-w-01) and (max-width: $max-w-02)  {
	  		left: 80%;
	  	}

	  	@media (max-width: $max-w-01) {
	  		opacity: 0;
	  	}

	}

	.parallax-area-03 {
	  	left: 73.5%;
	  	top: 9%;

	  	&:before {
	  		@extend .pole;
	  		left: 44px;
	  	}

	  	&.offer-page {
	  		left: 80%;

	  		&:before {
	  			left: 63px;
	  			width: 10px;
	  		}
	  	}

	  	@media (max-width: $max-w-02) {
	  		opacity: 0;
	  	}
	}


	.parallax-area-05 {
	  	left: 60%;

	  	&:before {
	  		@extend .pole;
	  		left: 61px;
	  	}

	  	&.offer-page {
	  		left: 65%;

	  		&:before {
	  			left: 17px;
	  		}
	  	}

	  	img {
	  		margin-top: -20%;
	  	}

	  	@include media-breakpoint-down(md) {
	  		transform: scale(.6);
	  		left: 56.5%;
	  	}
	}

	.parallax-area-04 {
		left: 10%;

		&:before {
	  		@extend .pole;
	  		left: 135px;
    		width: 15px;
    		max-height: 200vh;
    		transform: translateY(-20%);
	  	}


	  	&.v-long{
	  		left: 35%;

	  		&:before{
	  			left: 41px;
	  			max-height: 500%;
	  		}
	  	}

	  	&.offer-page {
	  		left: 32%;

	  		&:before {
	  			left: 44px;
	  			width: 10px;
	  		}

	  		img {
	  			margin-top: 90%;
	  		}
	  	}


	  	@include media-breakpoint-down(lg) {
	  		img {
	  			margin-top: -50%;
	  		}
	  	}

	  	
	  	@include media-breakpoint-between(sm, md) {
	  		transform: scale(.8);
	  		min-height: 300px;
	  		top: 67%;

	  		img {
	  			margin-top: -50%;
	  		}
	  	}


	  	@include media-breakpoint-down(md) {
	  		transform: scale(.7);
	  		top: 62%;

		  	&:before {
		  		max-height: 100%;
	    		transform: translateY(-50%);
		  	}

		  	&.v-long {
		  		&:before {
		  			max-height: 350%;
	    			transform: translateY(-50%);
		  		}
		  	}
	  	}

	  	@include media-breakpoint-down(sm) {
	  		left: -15%;

	  		&.v-long {
	  			top: 82%;
	  			left: 5%;
	  		}
	  	}


	  	@media (orientation: landscape) AND  (max-width: $max-w-02) {
	  		margin-top: 10%;

	  		
	  		&:before {
		  		max-height: 130%;
		  	}
	  	}

	}
 }
