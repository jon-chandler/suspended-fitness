:root {
	--bs-gutter-x: 0;
}
.card-container {
	padding-bottom: 160px;
	isolation: isolate;

	&--fill-bottom {
		padding-bottom: 650px;

		@include media-breakpoint-down(md) { 
			padding-bottom: 500px;
		}
	}

	.beacon {
		margin-top: -4em;
    	margin-left: -4em;
    	color: white;
    	transition: $transition-m;

    	&--content {
    		padding: 2em 6em;
    		position: absolute;
    		background: black;
    		width: 100%;
    	}

    	&--message {
    		font-size: 32px;
			line-height: 40px;
			padding: .5em;
			margin: 2px;
			
			a {
				margin-top: 16px;
			}
    	}

    	@include media-breakpoint-between(lg, xl) { 
    		margin-top: -1em;
    		margin-left: -1em;


    		&--content {
				padding: 1em;
			}
    	}

    	@include media-breakpoint-down(lg) { 
    		&--content {
				padding: 1em;
			}
    	}

    	@include media-breakpoint-down(md) { 
			margin-left: -1.5em;
		}
	}
}

.blurb {
	border: 2px solid red;
}

.content-card {
	border-radius: 0;
	border: none;
	padding: 4em;
	align-self: baseline;
	filter: drop-shadow(3px 3px 9px rgba(black, .1));
	transition: transition-bez;

	@include media-breakpoint-between(lg, xl) { 
		padding: 1em;
	}

	@include media-breakpoint-down(lg) { 
		margin-left: 0;
	}

	@include media-breakpoint-down(md) { 
		padding: 4em 1.5em;
	}

	&.shuffle {
		animation: shuffle-l $transition-m ease-in-out;
	}

	&:nth-of-type(2) {
		margin-top: 130px;
		align-self: self-start;

		&.shuffle {
			animation: shuffle-r $transition-m ease-in-out;
		}
		
		@include media-breakpoint-down(lg) { 
			margin-top: 0px;
		}
	}

	&--pull-left {
		margin-left: 0;
		transform: translateX(-2em);

		@include media-breakpoint-down(lg) { 
	        transform: translateX(0);
	    }
	}

	&--top {
		z-index: 4;
	}

	&--white {
		background: white;
	}

	&--pink {
		background: $cardPink;
	}

	&--blue {
		background: $coreBlue;
	}

	&--altBlue {
		background: $altBlue;
	}

	&--grey {
		background: $nGrey;
	}

	&--yellow {
		background: $altYellow;
	}

	&--pale-yellow {
		background: $offerYellow;
	}

	&--green {
		background: $offerGreen;
	}

	img {
		min-width: 100%;
	}

	li {
		line-height: 2.5em;
	}

	.info-list {
		list-style-type: circle;
		margin-left: 1.5em;
		padding-bottom: 2em;

		li {
			line-height: unset;
		}

	}

	a {
		display: inline-block;
		color: black;
		@extend .pseudo-ul;

		&:hover:after {
			background: black;
		}
	}

}

@keyframes shuffle-r {
	0% {
		transform: translateX(0);
	}
	50% {
		transform: translateX(8%) scale(1.04);
	}
	1000% {
		transform: translateX(0%);
	}
}

@keyframes shuffle-l {
	0% {
		transform: translateX(0);
	}
	50% {
		transform: translateX(-8%) scale(1.04);
	}
	1000% {
		transform: translateX(0%);
	}
}
