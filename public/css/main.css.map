header {

	@include media-breakpoint-down(md) {
        padding: 0 2em;
    }

	.logo {
		
		a{
			display: block;
			width: 200px;
			height: 148px !important;
		}

		@include media-breakpoint-down(md) { 
			img {
				width: 140px;
				height: 102px;	
			}
		}
		
	}

	.menu {
		display: block;
		width: 32px;
		height: 40px;
		background: url('/images/menu_icon_on.svg');
		background-size: contain;
    	background-repeat: no-repeat;
    	background-position: top center;
		transition: $transition-f;
		cursor: pointer;

		&:hover {
			transform: skew(-0.2rad) rotate(-11deg);
		}
	}

}