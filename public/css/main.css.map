.card {
	padding: 4em;
	border-radius: unset;
	transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.35);
	transform: translateY(100px);
	position: relative;

	&.show {
		transform: translateY(0);
	}
	
	&:nth-child(even) {
		@extend .offset-md-2;
	}

	&:last-of-type {
		margin-bottom: 280px !important;
	}

	@include media-breakpoint-down(lg) { 
		margin-left: unset !important;
	}

	&:nth-child(4n-1) {
	 	background: $offerPink;

	 	img {
	 		@extend .filter--pink;
	 	}
    }
    &:nth-child(4n-2) {
    	background: $offerYellow;

    	img {
	 		@extend .filter--yellow;
	 	}
    }
    &:nth-child(4n-3) {
    	background: $offerBlue;

    	img {
	 		@extend .filter--blue;
	 	}
    }
    &:nth-child(4n-4) {
    	background: $offerGreen;

    	img {
	 		@extend .filter--green;
	 	}
    }

    img {
    	max-height: 400px;
    	aspect-ratio: auto;
    }

    &--action-container {
    	display: flex;
    	margin-top: 1em;
    	
    	> button {
    		margin-right: 2em;
    	}
    }

    .card-text {

    	&--info {
    		color: $charcoal;
    		@extend .haptik--small;
    	}
    }

}